# LLM (pick one provider)
OPENAI_API_KEY=         # or use OPENAI_KEY as an alias
OPENAI_KEY=             # alternative alias for OPENAI_API_KEY
ANTHROPIC_API_KEY=

# Model override (optional — defaults to claude-3-5-sonnet-20241022)
# Any LiteLLM-supported model string: https://docs.litellm.ai/docs/providers
STEM_AGENT_MODEL=       # e.g. gpt-4o, claude-3-5-sonnet-20241022, gemini/gemini-1.5-pro
MODEL=                  # alternative alias for STEM_AGENT_MODEL

# Optional integrations
TAVILY_API_KEY=         # enables live web search in multi_step_search architecture
SEMANTIC_SCHOLAR_API_KEY=  # raises Phase 0 rate limits
